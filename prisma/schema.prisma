generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum MaterialType {
  article
  code_rule
  prompt
  feedback
  failed_output
  note
  project_description
}

enum MaterialStatus {
  unprocessed
  analyzed
  used
  archived
}

enum InsightType {
  preference
  principle
  boundary
  style
  workflow
  anti_pattern
}

enum ProposalCategory {
  personal
  ai_collaboration
  coding
  writing
  knowledge
  product
}

enum ProposalAction {
  add
  modify
  delete
}

enum ProposalStatus {
  pending
  accepted
  rejected
  edited
}

enum RuleStatus {
  active
  archived
}

enum WorkflowType {
  analyze_material
  generate_artifact
  playground_run
  feedback_to_proposal
}

enum WorkflowStatus {
  pending
  running
  waiting_for_human
  completed
  failed
  cancelled
}

enum TriggerSource {
  user_action
  system_retry
}

enum StepStatus {
  pending
  running
  completed
  failed
  skipped
}

enum LLMRunStatus {
  success
  parse_failed
  model_failed
}

model User {
  id         String      @id @default(cuid())
  email      String      @unique
  name       String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  workspace  Workspace?
}

model Workspace {
  id                String         @id @default(cuid())
  userId            String         @unique
  name              String
  description       String?        @db.Text
  identity          String?
  primaryScenarios  Json?
  rememberNotes     String?        @db.Text
  dislikedBehaviors Json?
  outputPreferences Json?
  exportGoals       Json?
  profileSummary    String?        @db.Text
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  materials         Material[]
  insights          Insight[]
  ruleProposals     RuleProposal[]
  rules             Rule[]
  workflowRuns      WorkflowRun[]
}

model Material {
  id          String          @id @default(cuid())
  workspaceId String
  type        MaterialType
  title       String
  summary     String?         @db.Text
  content     String          @db.LongText
  tags        Json?
  status      MaterialStatus  @default(unprocessed)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  insights    Insight[]
  proposals   RuleProposal[]
  rules       Rule[]

  @@index([workspaceId, status, createdAt])
}

model Insight {
  id          String       @id @default(cuid())
  workspaceId String
  materialId  String
  type        InsightType
  title       String
  description String       @db.Text
  evidence    String       @db.Text
  confidence  Float
  createdAt   DateTime     @default(now())
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  material    Material     @relation(fields: [materialId], references: [id], onDelete: Cascade)
  proposals   RuleProposal[]

  @@index([workspaceId, materialId, createdAt])
}

model RuleProposal {
  id                String           @id @default(cuid())
  workspaceId       String
  materialId        String?
  insightId         String?
  title             String
  category          ProposalCategory
  action            ProposalAction
  proposedContent   String           @db.Text
  reason            String           @db.Text
  evidence          String           @db.Text
  affectedArtifacts Json?
  confidence        Float?
  status            ProposalStatus   @default(pending)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  workspace         Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  material          Material?        @relation(fields: [materialId], references: [id], onDelete: SetNull)
  insight           Insight?         @relation(fields: [insightId], references: [id], onDelete: SetNull)
  rules             Rule[]

  @@index([workspaceId, status, createdAt])
}

model Rule {
  id               String         @id @default(cuid())
  workspaceId      String
  category         ProposalCategory
  title            String
  content          String         @db.Text
  sourceProposalId String?
  sourceMaterialId String?
  status           RuleStatus     @default(active)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  workspace        Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceProposal   RuleProposal?  @relation(fields: [sourceProposalId], references: [id], onDelete: SetNull)
  sourceMaterial   Material?      @relation(fields: [sourceMaterialId], references: [id], onDelete: SetNull)

  @@index([workspaceId, category, status, updatedAt])
}

model WorkflowRun {
  id            String         @id @default(cuid())
  workspaceId   String
  workflowType  WorkflowType
  status        WorkflowStatus @default(pending)
  triggerSource TriggerSource
  startedAt     DateTime       @default(now())
  finishedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stepRuns      StepRun[]

  @@index([workspaceId, workflowType, startedAt])
}

model StepRun {
  id             String       @id @default(cuid())
  workflowRunId  String
  stepName       String
  status         StepStatus   @default(pending)
  inputSnapshot  String       @db.LongText
  outputSnapshot String?      @db.LongText
  errorMessage   String?      @db.Text
  startedAt      DateTime     @default(now())
  finishedAt     DateTime?
  workflowRun    WorkflowRun  @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  llmRuns        LLMRun[]

  @@index([workflowRunId, startedAt])
}

model LLMRun {
  id           String       @id @default(cuid())
  stepRunId    String
  model        String
  promptName   String
  promptVersion String
  inputTokens  Int?
  outputTokens Int?
  rawRequest   String       @db.LongText
  rawResponse  String?      @db.LongText
  parsedOutput String?      @db.LongText
  status       LLMRunStatus
  createdAt    DateTime     @default(now())
  stepRun      StepRun      @relation(fields: [stepRunId], references: [id], onDelete: Cascade)

  @@index([stepRunId, createdAt])
}
